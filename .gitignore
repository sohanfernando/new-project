# OS-generated files
.DS_Store
Thumbs.db

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo

# Environment files (root-level)
.env
.env.*
!.env.example

# Backend ignores (root-level safety net; backend/.gitignore covers in-tree)
backend/.venv/
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.py[cod]
backend/.pytest_cache/
backend/*.db
backend/*.sqlite3
backend/uploads/

# Frontend ignores (root-level safety net)
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/vite.config.ts.timestamp-*
frontend/*.log
